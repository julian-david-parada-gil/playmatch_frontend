{
  "name": "playmatch",
  "version": "0.0.1-SNAPSHOT",
  "private": true,
  "description": "Description for Playmatch",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "npm run webapp:prod --",
    "build-watch": "concurrently 'npm run webapp:build:dev -- --watch'",
    "ci:frontend:test": "npm run webapp:build:$npm_package_config_default_environment && npm run test",
    "clean-www": "rimraf target/classes/static/",
    "cleanup": "rimraf target/",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "sonar": "sonar-scanner",
    "start": "npm run webapp:dev --",
    "start-tls": "npm run webapp:dev -- --env tls",
    "pretest": "npm run lint",
    "test": "npm run vitest-run --",
    "test:watch": "npm run vitest --",
    "vitest": "vitest",
    "vitest-run": "vitest run --coverage",
    "watch": "concurrently 'npm run start' npm:backend:start",
    "webapp:build": "npm run clean-www && npm run webapp:build:dev --",
    "webapp:build:dev": "webpack --config webpack/webpack.dev.js --env stats=minimal",
    "webapp:build:prod": "webpack --config webpack/webpack.prod.js --progress=profile",
    "webapp:dev": "npm run webpack-dev-server -- --config webpack/webpack.dev.js --env stats=minimal",
    "webapp:dev-verbose": "npm run webpack-dev-server -- --config webpack/webpack.dev.js --progress=profile --env stats=normal",
    "webapp:prod": "npm run clean-www && npm run webapp:build:prod --",
    "webapp:test": "npm run test --",
    "webpack-dev-server": "webpack serve"
  },
  "config": {
    "default_environment": "prod"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@reduxjs/toolkit": "2.12.0",
    "axios": "1.16.1",
    "bootstrap": "5.3.8",
    "bootswatch": "5.3.8",
    "dayjs": "1.11.21",
    "path-browserify": "1.0.1",
    "react": "19.2.6",
    "react-bootstrap": "2.10.10",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.1",
    "react-jhipster": "1.0.3",
    "react-redux": "9.3.0",
    "react-router": "7.15.1",
    "react-toastify": "11.1.0",
    "react-top-loading-bar": "3.0.2",
    "redux": "5.0.1",
    "sonar-scanner": "3.1.0",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.8.5",
    "@eslint/js": "10.0.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/webpack-env": "1.18.8",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "browser-sync": "3.0.4",
    "browser-sync-webpack-plugin": "2.4.0",
    "concurrently": "9.2.1",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "css-minimizer-webpack-plugin": "8.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "generator-jhipster": "9.1.0",
    "happy-dom": "20.9.0",
    "html-webpack-plugin": "5.6.7",
    "identity-obj-proxy": "3.0.0",
    "mini-css-extract-plugin": "2.10.2",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "react-infinite-scroll-component": "7.2.0",
    "rimraf": "6.1.3",
    "sass": "1.77.6",
    "sass-loader": "17.0.0",
    "simple-progress-webpack-plugin": "2.0.0",
    "source-map-loader": "5.0.0",
    "style-loader": "4.0.0",
    "swagger-ui-dist": "5.32.6",
    "terser-webpack-plugin": "5.6.0",
    "thread-loader": "4.0.4",
    "ts-loader": "9.5.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "vitest-sonar-reporter": "3.0.0",
    "wait-on": "9.0.10",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.4",
    "webpack-merge": "6.0.1",
    "webpack-notifier": "1.15.0",
    "workbox-webpack-plugin": "7.4.1"
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
